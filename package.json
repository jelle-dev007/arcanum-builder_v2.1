{
  "name": "arcanum-builder",
  "private": true,
  "version": "2.2.0",
  "description": "A worldbuilding tool for creating and managing chronicle records, maps, and journal entries.",
  "author": "Arcanum Builder",
  "type": "commonjs",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:start": "npm run build && electron .",
    "desktop:package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "html-to-image": "^1.11.13",
    "konva": "^10.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.arcanum.builder",
    "productName": "Arcanum Builder",
    "copyright": "Copyright © 2025 Arcanum Builder",
    "directories": {
      "output": "../Arcanum-Builder_v2.2"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/ArcanumICON.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arcanum Builder"
    },
    "mac": {
      "icon": "src/assets/ArcanumICON.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "Arcanum Builder",
      "window": { "width": 540, "height": 380 }
    }
  }
}
